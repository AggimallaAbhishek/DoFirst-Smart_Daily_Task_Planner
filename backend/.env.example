NODE_ENV=development
PORT=4301
DATABASE_URL=postgresql://planner:planner@localhost:5433/smart_daily_planner
JWT_SECRET=change-me
JWT_EXPIRES_IN=24h
FRONTEND_ORIGIN=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ENABLE_NATIVE_APP_ORIGINS=true
NATIVE_APP_ORIGINS=http://localhost,https://localhost,capacitor://localhost,ionic://localhost
LOG_LEVEL=debug
AUTH_RATE_LIMIT_MAX=5
API_RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000
REQUEST_TIMEOUT_MS=30000
SLOW_REQUEST_THRESHOLD_MS=1000
HEALTH_CHECK_CACHE_MS=3000
TRUST_PROXY=false
DB_SSL_REJECT_UNAUTHORIZED=false
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000
DB_QUERY_TIMEOUT_MS=10000
DB_STATEMENT_TIMEOUT_MS=12000
DB_CONNECT_MAX_RETRIES=6
DB_CONNECT_RETRY_DELAY_MS=3000
DB_STARTUP_REQUIRED=true
TASK_READ_CACHE_TTL_MS=1500
AWS_REGION=ap-south-1
AWS_SECRETS_MANAGER_SECRET_ID=
SENTRY_DSN=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_ADDITIONAL_CLIENT_IDS=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=postmessage
