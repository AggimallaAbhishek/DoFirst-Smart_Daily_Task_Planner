{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build": "node -e \"console.log('Backend build step complete.')\"",
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.js\"",
    "test": "jest --runInBand --coverage",
    "test:unit": "jest --runInBand --coverage=false tests/unit",
    "test:integration": "jest --runInBand --coverage=false tests/integration",
    "test:watch": "jest --watch",
    "db:migrate": "node src/db/migrate.js"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.812.0",
    "@sentry/node": "^8.46.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.0.1",
    "google-auth-library": "^9.15.1",
    "helmet": "^8.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-plugin-security": "^3.0.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.1"
  }
}
